# ──────────────────────────────────────────────────────────
# Kalam Spark — Backend Environment Variables
# Copy this file to .env inside the /backend directory.
# ──────────────────────────────────────────────────────────

# ── Cloud AI API Keys (Gemma4 via 3-platform auto-failover)
# OpenRouter (primary — free tier: Gemma 27B)
OPENROUTER_API_KEY=your_openrouter_key_here

# Google Gemini AI Studio (last resort)
GEMINI_API_KEY=your_gemini_key_here

# ── Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173,https://your-frontend.onrender.com
